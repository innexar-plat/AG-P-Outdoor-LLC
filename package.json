{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/admin\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:admin": "npm run dev --prefix apps/admin",
    "build": "npm run build --prefix apps/web && npm run build --prefix apps/admin",
    "build:admin": "npm run build --prefix apps/admin",
    "build:web": "npm run build --prefix apps/web",
    "start": "concurrently --kill-others --raw",
    "lint": "concurrently --raw \"npm run lint --prefix apps/web\" \"npm run lint --prefix apps/admin\"",
    "lint:admin": "npm run lint --prefix apps/admin",
    "lint:web": "npm run lint --prefix apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1"
  }
}
