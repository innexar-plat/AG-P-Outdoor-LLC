NODE_ENV=production
# Public URLs (ajuste conforme seu domínio real)
SERVICE_URL_WEB=https://agpoutdoor.com
SERVICE_URL_ADMIN=https://agpoutdoor.com/admin/
# Better Auth (para redirects/links)
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=https://agpoutdoor.com/admin/
# Resend (opcional)
RESEND_API_KEY=
NOTIFICATION_EMAIL=
# GA4 (opcional)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_KEY=
# ---------------------------------------------------------------------------
# Banco (libsql/Turso)
# - Em produção com docker-compose (serviços na mesma rede): http://sqld:8080
# - Next.js rodando NO HOST (npm run dev): suba só o sqld (compose) e use a porta
#   mapeada no compose (127.0.0.1:18523 -> 8080), ex.:
#   DATABASE_URL=http://127.0.0.1:18523
#   Nunca use o hostname "sqld" fora do Docker — o DNS falha (EAI_AGAIN).
# - Turso na nuvem: libsql://... com DATABASE_AUTH_TOKEN.
# ---------------------------------------------------------------------------
TURSO_DATABASE_URL=http://sqld:8080
DATABASE_URL=http://sqld:8080
TURSO_AUTH_TOKEN=
DATABASE_AUTH_TOKEN=
# ---------------------------------------------------------------------------
# S3-compatible (MinIO)
# Importante:
# - S3_ENDPOINT para o backend: http://minio:9000 (nome do serviço na rede Docker)
# - S3_PUBLIC_URL para gerar URLs públicas no browser: use seu domínio/sslip/host
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=agpoutdoor-minio
S3_SECRET_ACCESS_KEY=please-change-me-very-soon
S3_BUCKET_NAME=uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# Do seu print/env anterior, o MinIO está em:
# SERVICE_URL_MINIO=http://ltbmzi1kp567z6uuygqi0mv5.10.10.10.103.sslip.io
S3_PUBLIC_URL=http://ltbmzi1kp567z6uuygqi0mv5.10.10.10.103.sslip.io/uploads
# Variáveis NEXT/Vite (para o frontend)
NEXT_PUBLIC_URL=https://agpoutdoor.com
NEXT_PUBLIC_APP_URL=https://agpoutdoor.com/admin/
VITE_API_URL=https://agpoutdoor.com/admin/
VITE_ADMIN_URL=https://agpoutdoor.com/admin/