# =============================================================================
# Innexar Admin Panel — Environment Variables
# Copy to .env.local and fill in the values
# =============================================================================

# Database (Turso / libsql)
# Local dev with Docker: http://sqld:8080 (or http://127.0.0.1:8080 from host)
# Production: libsql://your-db.turso.io
TURSO_DATABASE_URL=http://127.0.0.1:8080
DATABASE_URL=http://127.0.0.1:8080
TURSO_AUTH_TOKEN=
DATABASE_AUTH_TOKEN=

# Better Auth
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# Resend (email notifications)
RESEND_API_KEY=
NOTIFICATION_EMAIL=

# Google Analytics 4 Data API (optional)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_KEY=

# ---------------------------------------------------------------------------
# Image Storage (S3-compatible)
# Priority: R2 vars → S3 vars → base64 fallback
# ---------------------------------------------------------------------------

# Option A: Cloudflare R2 (production)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://cdn.yourdomain.com

# Option B: MinIO or any S3-compatible (dev / self-hosted fallback)
# Docker dev defaults (auto-configured in docker-compose.yml):
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=uploads
S3_PUBLIC_URL=http://localhost:9000/uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Public URL (CORS, auth trusted origins)
NEXT_PUBLIC_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
